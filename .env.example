# Jina AI — used for embeddings (jina-embeddings-v3) — free tier
JINA_API_KEY=jina_...

# Grok (xAI) — used for chat completions
GROK_API_KEY=xai-...

# Qdrant Cloud — get a free cluster at https://cloud.qdrant.io
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Collection name used in Qdrant
QDRANT_COLLECTION=notebook-lm-rag
